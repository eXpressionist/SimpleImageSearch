# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/imagesearch

# Search Provider: "brave" (recommended), "serpapi", or "google"
SEARCH_PROVIDER=brave

# Brave Search API - Images
# Get key at https://brave.com/search/api/ - 2000 requests/month free
BRAVE_API_KEY=

# Brave search settings
BRAVE_COUNT=5
BRAVE_SAFESEARCH=off
BRAVE_COUNTRY=US
BRAVE_SEARCH_LANG=en

# SerpAPI (alternative)
SERPAPI_API_KEY=
SERPAPI_ENGINE=google_images

# Google Custom Search (deprecated)
GOOGLE_API_KEY=
GOOGLE_CSE_CX=

# Storage
STORAGE_PATH=/data/images

# Limits
MAX_FILE_SIZE_MB=10
DOWNLOAD_TIMEOUT=30
MAX_CONCURRENT_DOWNLOADS=5
MAX_RETRIES=3
RETRY_BACKOFF_BASE=2

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD_SECONDS=60

# Logging
LOG_LEVEL=INFO

# Security
ALLOWED_DOMAINS=
BLOCKED_DOMAINS=